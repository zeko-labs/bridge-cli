#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/o1js@2.8.0/node_modules/o1js/src/build/node_modules:/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/o1js@2.8.0/node_modules/o1js/src/node_modules:/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/o1js@2.8.0/node_modules/o1js/node_modules:/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/o1js@2.8.0/node_modules:/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/o1js@2.8.0/node_modules/o1js/src/build/node_modules:/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/o1js@2.8.0/node_modules/o1js/src/node_modules:/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/o1js@2.8.0/node_modules/o1js/node_modules:/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/o1js@2.8.0/node_modules:/home/runner/work/zeko-ui/zeko-ui/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../o1js/src/build/run.js" "$@"
else
  exec node  "$basedir/../o1js/src/build/run.js" "$@"
fi
