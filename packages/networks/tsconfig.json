{
	"compilerOptions": {
		"target": "ES2022",
		"module": "esnext",
		"lib": ["ES2022"],
		"moduleResolution": "bundler",
		"strict": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"skipLibCheck": true
	},
	"include": ["src", "tests"]
}
